# Server port (default: 2026)
PORT=2026

# Log level: debug, info, warn, error (default: info)
LOG_LEVEL=info

# Neural network AI inference server (optional, not required for rule-engine NPCs)
AI_SERVER_URL=http://localhost:8900
NPC_MODEL_ENABLED=off
NPC_MODEL_URL=http://localhost:8900
NPC_MODEL_TIMEOUT_MS=800
NPC_MODEL_MIN_CONFIDENCE=0.18

# Save data directory (default: /app/data in Docker, ./data locally)
SAVE_DIR=./data

# Optional npm registry mirror for Docker builds on slow or self-hosted networks.
# Example: https://registry.npmmirror.com
NPM_REGISTRY=

# API rate limiting for self-hosted deployments.
HTTP_RATE_LIMIT=240
HTTP_RATE_WINDOW_MS=60000

# Optional legacy single-spot solver runtime mount for validated HU deployment.
# Example path:
# /path/to/lonicera/solver-workloads/phase1-btn-vs-bb-srp-50bb-full/runtime/BTN_vs_BB/SRP_50bb
SOLVER_BTN_BB_SRP_50BB_RUNTIME=
# Optional local runtime root override (the directory that contains BTN_vs_BB/SRP_50bb).
# Example path:
# /path/to/lonicera/solver-workloads/phase1-btn-vs-bb-srp-50bb-full/runtime
SOLVER_DATA_DIR=
# Optional local root-only cache for flop-root exact-hit lookups.
# Example path:
# /path/to/lonicera/solver-workloads/phase1-btn-vs-bb-srp-50bb-full/root-runtime-cache
SOLVER_ROOT_CACHE_DIR=
